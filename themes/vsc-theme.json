{
  "name": "pretty-dark-theme-plus",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "enumMember": {
      "foreground": "#56b6c2"
    },
    "variable.constant": {
      "foreground": "#e5c07b"
    },
    "variable.defaultLibrary": {
      "foreground": "#e5c07b"
    },
    "variable:dart": {
      "foreground": "#e5c07b"
    },
    "property:dart": {
      "foreground": "#e06c75"
    },
    "annotation:dart": {
      "foreground": "#d19a66",
      "fontStyle": "normal"
    },
    "parameter.label:dart": {
      "foreground": "#e06c75"
    },
    "macro": {
      "foreground": "#d19a66"
    },
    "tomlArrayKey": {
      "foreground": "#e5c07b"
    },
    "type": {
      "foreground": "#4ec9b0",
      "fontStyle": "normal"
    },
    "class": {
      "foreground": "#4ec9b0",
      "fontStyle": "normal"
    },
    "interface": {
      "foreground": "#4ec9b0",
      "fontStyle": "normal"
    },
    "typeParameter": {
      "foreground": "#4ec9b0",
      "fontStyle": "normal"
    },
    "tag": {
      "foreground": "#d19a66"
    },
    "property": {
      "foreground": "#d19a66"
    }
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#ffc3bab7"
      }
    },
    {
      "name": "Keywords (generic + JS/TS/Java/Go/Rust/etc.)",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.word",
        "keyword.operator.module",
        "keyword.operator.optional",
        "keyword.operator.ternary",
        "keyword.operator.assignment",
        "keyword.operator.expression.keyof",
        "keyword.operator.expression.instanceof",
        "keyword.operator.expression.delete",
        "keyword.operator.expression.typeof",
        "keyword.operator.expression.void",
        "keyword.operator.expression.in",
        "keyword.operator.expression.of",
        "keyword.operator.instanceof.java"
      ],
      "settings": {
        "foreground": "#c678dd",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Logical / Bitwise Operators",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.channel",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.decrement",
        "keyword.operator.increment",
        "keyword.operator.assignment.compound",
        "keyword.operator.assignment.compound.js",
        "keyword.operator.assignment.compound.ts",
        "keyword.operator.logical.python",
        "keyword.operator.logical.php",
        "keyword.operator.bitwise.php",
        "keyword.operator.arithmetic.php",
        "keyword.operator.assignment.go",
        "keyword.operator.arithmetic.go",
        "keyword.operator.address.go",
        "keyword.operator.misc.rust",
        "keyword.operator.sigil.rust"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "this / self",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.parameter.function.language.special.self.python",
        "variable.parameter.function.language.special.cls.python",
        "variable.language.rust"
      ],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "name": "Variables (generic + many languages)",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.local",
        "variable.other.field",
        "variable.other.object",
        "variable.other.object.property",
        "variable.other.property",
        "meta.object-literal.key",
        "variable.other.readwrite.c",
        "variable.other.readwrite.cpp",
        "variable.other.readwrite.java",
        "variable.other.readwrite.cs",
        "meta.method.body.java",
        "entity.name.variable.local.cs",
        "entity.name.variable.field.cs",
        "entity.name.variable.parameter.cs",
        "variable.parameter",
        "variable.parameter.function",
        "variable.parameter.function.js",
        "variable.parameter.function.language.python",
        "variable.parameter.function.c",
        "variable.parameter.function.ruby",
        "variable.parameter.function.kotlin",
        "variable.parameter.function.swift",
        "variable.parameter.function.latex",
        "function.parameter",
        "function.parameter.ruby",
        "function.parameter.cs",
        "meta.definition.variable.name.java",
        "meta.definition.variable.name.groovy",
        "text.variable",
        "text.bracketed"
      ],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "name": "Struct / object fields",
      "scope": [
        "variable.other.field",
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "variable.object.property.tsx",
        "entity.name.field",
        "entity.name.field.rust",
        "entity.name.field.go"
      ],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "Java punctuation terminator",
      "scope": [
        "punctuation.terminator.java"
      ],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "Constant variables",
      "scope": [
        "variable.other.constant",
        "variable.other.readonly"
      ],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "name": "Functions / Methods",
      "scope": [
        "entity.name.function",
        "meta.function",
        "meta.function.c",
        "meta.function.cpp",
        "meta.function.rust",
        "meta.function.go",
        "meta.function.php",
        "meta.function.cs",
        "meta.function.kotlin",
        "meta.function.swift",
        "meta.require",
        "support.function.any-method",
        "variable.function",
        "support.function.console",
        "meta.function-call.generic.python",
        "support.function.std.rust",
        "support.function",
        "keyword.other.special-method",
        "support.function.console",
        "support.function.builtin.go",
        "support.function.builtin.rust"
      ],
      "settings": {
        "foreground": "#61afef"
      }
    },
    {
      "name": "Types / Classes / Interfaces",
      "scope": [
        "support.type",
        "support.type.sys-types",
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type.primitive.ts",
        "support.type.builtin.ts",
        "support.type.primitive.tsx",
        "support.type.builtin.tsx",
        "support.type.swift",
        "support.type.kotlin",
        "support.type.vb.asp",
        "entity.name.type.parameter",
        "support.type.prelude.elm",
        "support.type.texture.hlsl",
        "support.type.sampler.hlsl",
        "support.type.object.hlsl",
        "support.type.object.rw.hlsl",
        "support.type.fx.hlsl",
        "storage.type.cs",
        "storage.type.java",
        "storage.type.generic.java",
        "storage.type.primitive.java",
        "storage.type.annotation.java",
        "storage.type.object.array.java",
        "keyword.type",
        "keyword.type.cs",
        "keyword.type.java",
        "keyword.predefined.type",
        "keyword.predefined.type.cs",
        "keyword.predefined.type.java"
      ],
      "settings": {
        "foreground": "#4ec9b0",
        "fontStyle": ""
      }
    },
    {
      "name": "Type keywords (struct / class / namespace)",
      "scope": [
        "storage.type",
        "storage.type.swift",
        "storage.type.kotlin",
        "storage.type.rust",
        "storage.type.go",
        "storage.type.dart",
        "storage.type.struct.rust",
        "storage.type.enum.rust",
        "storage.type.union.rust",
        "storage.type.class.python",
        "storage.type.class.cs",
        "storage.type.namespace.cs",
        "storage.type.namespace.ts",
        "storage.type.namespace.js"
      ],
      "settings": {
        "foreground": "#c678dd",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go builtin types (int, string, etc.)",
      "scope": [
        "storage.type.numeric.go",
        "storage.type.byte.go",
        "storage.type.boolean.go",
        "storage.type.string.go",
        "storage.type.error.go",
        "storage.type.rune.go",
        "support.type.builtin.go",
        "support.type.go"
      ],
      "settings": {
        "foreground": "#4ec9b0",
        "fontStyle": ""
      }
    },
    {
      "name": "Enums / Constants (Go / Rust / Java / C# / Swift / Kotlin / Dart)",
      "scope": [
        "constant.other.enum",
        "entity.name.enum",
        "constant.other.enummember",
        "support.constant.core.rust",
        "support.constant.ext.php",
        "support.constant.std.php",
        "support.constant.core.php",
        "support.constant.parser-token.php",
        "support.constant.property-value.scss",
        "support.constant.elm",
        "constant.language.symbol.ruby",
        "constant.language.symbol.hashkey.ruby",
        "constant.language.symbol.elixir",
        "constant.language.symbol.double-quoted.elixir"
      ],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "Namespaces / Modules / Packages",
      "scope": [
        "support.other.namespace.use.php",
        "support.other.namespace.use-as.php",
        "entity.other.alias.php",
        "meta.interface.php",
        "support.type.object.module",
        "support.module.node",
        "entity.name.type.module",
        "entity.name.package.go",
        "token.package.keyword",
        "token.package"
      ],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "name": "Namespace names",
      "scope": [
        "entity.name.namespace",
        "entity.name.type.namespace",
        "entity.name.type.namespace.cs",
        "support.other.namespace",
        "support.other.namespace.cs"
      ],
      "settings": {
        "foreground": "#e5c07b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Generic constants / numbers",
      "scope": [
        "constant",
        "constant.numeric",
        "punctuation.definition.constant",
        "constant.numeric.decimal.asm.x86_64"
      ],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "Language Constants (null, true, false, etc.)",
      "scope": [
        "constant.language",
        "constant.language.json",
        "source.json meta.structure.dictionary.json > constant.language.json",
        "source.json meta.structure.array.json > constant.language.json"
      ],
      "settings": {
        "foreground": "#d19a66",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings (all languages)",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.triple",
        "string.interpolated",
        "markup.inline.raw.markdown",
        "markup.inline.raw.string.markdown",
        "markup.raw.monospace.asciidoc",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "keyword.operator.quantifier.regexp",
        "support.other.parenthesis.regexp",
        "support.other.parenthesis.regexp",
        "support.constant.edge",
        "keyword.operator.regexp.php"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Template strings / interpolation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded",
        "meta.template.expression",
        "keyword.other.template.begin",
        "keyword.other.template.end",
        "keyword.other.substitution.begin",
        "keyword.other.substitution.end",
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php",
        "variable.interpolation"
      ],
      "settings": {
        "foreground": "#c678dd"
      }
    },
    {
      "name": "JSON keys / values",
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name.json punctuation",
        "source.json meta.structure.dictionary.json > string.quoted.json",
        "source.json meta.structure.dictionary.json > string.quoted.json > punctuation",
        "source.json meta.structure.dictionary.json > value.json > string.quoted.json",
        "source.json meta.structure.array.json > value.json > string.quoted.json",
        "source.json meta.structure.dictionary.json > value.json > string.quoted.json > punctuation",
        "source.json meta.structure.array.json > value.json > string.quoted.json > punctuation",
        "support.constant.json"
      ],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "name": "CSS / SCSS / LESS",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css",
        "support.constant.property-value.css",
        "support.constant.color.w3c-standard-color-name.css",
        "support.constant.property-value.scss",
        "support.constant.property-value",
        "support.constant.font-name",
        "rgb-value",
        "inline-color-decoration rgb-value",
        "less rgb-value",
        "selector.sass",
        "keyword.operator.css",
        "keyword.operator.scss",
        "keyword.operator.less",
        "support.constant.color.w3c-standard-color-name.scss",
        "punctuation.separator.list.comma.css"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "HTML / JSX tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "invalid.illegal-unrecognized-tag.html",
        "constant.character.entity"
      ],
      "settings": {
        "foreground": "#6f9bff"
      }
    },
    {
      "name": "HTML / JSX attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.pseudo-element",
        "entity.other.attribute-name.pseudo-class"
      ],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "HTML / JSX angle brackets",
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#c2c2c2"
      }
    },
    {
      "name": "Markdown headings / sections",
      "scope": [
        "markup.heading",
        "markup.heading punctuation.definition.heading",
        "entity.name.section",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown",
        "markup.heading.setext",
        "markup.heading.setext.1.markdown",
        "markup.heading.setext.2.markdown",
        "punctuation.definition.block.sequence.item.yaml"
      ],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "name": "Markdown lists",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "punctuation.definition.list.markdown",
        "beginning.punctuation.definition.list.markdown",
        "markup.list.asciidoc"
      ],
      "settings": {
        "foreground": "#6f9bff"
      }
    },
    {
      "name": "Markdown block quotes",
      "scope": [
        "markup.quote.markdown"
      ],
      "settings": {
        "foreground": "#636b78"
      }
    },
    {
      "name": "Markdown emphasis / strong",
      "scope": [
        "markup.bold",
        "todo.bold",
        "punctuation.definition.bold",
        "punctuation.definition.bold.markdown",
        "markup.italic",
        "punctuation.definition.italic",
        "todo.emphasis"
      ],
      "settings": {
        "foreground": "#c678dd",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown / AsciiDoc code & raw",
      "scope": [
        "markup.inline.raw.markdown",
        "markup.inline.raw.string.markdown",
        "punctuation.definition.raw.markdown",
        "markup.raw.monospace.asciidoc",
        "punctuation.definition.asciidoc"
      ],
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link.markdown",
        "markup.underline.link.image.markdown",
        "string.other.link.title.markdown",
        "string.other.link.description.markdown",
        "punctuation.definition.string.begin.markdown",
        "punctuation.definition.string.end.markdown",
        "punctuation.definition.metadata.markdown",
        "markup.link.asciidoc",
        "markup.other.url.asciidoc"
      ],
      "settings": {
        "foreground": "#61afef"
      }
    },
    {
      "name": "Diff / Git",
      "scope": [
        "markup.inserted.diff",
        "markup.deleted.diff",
        "markup.changed.diff",
        "meta.diff.header.from-file",
        "meta.diff.header.to-file",
        "punctuation.definition.from-file.diff",
        "punctuation.definition.to-file.diff"
      ],
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "name": "Diagnostics tokens",
      "scope": [
        "token.info-token",
        "token.warn-token",
        "token.error-token",
        "token.debug-token",
        "log.info",
        "log.warning",
        "log.error"
      ],
      "settings": {
        "foreground": "#c678dd"
      }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": [
        "invalid.illegal",
        "invalid.broken",
        "invalid.deprecated",
        "invalid.unimplemented",
        "invalid.deprecated.entity.other.attribute-name.html",
        "invalid.illegal.bad-ampersand.html",
        "invalid.illegal.non-null-typehinted.php",
        "invalid.illegal.unrecognized-tag.html"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Punctuation / Delimiters",
      "scope": [
        "punctuation.separator.delimiter",
        "punctuation.separator.key-value",
        "punctuation.separator.comma",
        "punctuation.section.block",
        "punctuation.section.scope",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end",
        "meta.brace.square",
        "punctuation.separator.c",
        "punctuation.separator.cpp",
        "punctuation.section.array.begin.php",
        "punctuation.section.array.end.php",
        "punctuation.definition.parameters.begin.bracket.round.php",
        "punctuation.definition.parameters.end.bracket.round.php"
      ],
      "settings": {
        "foreground": "#c2c2c2"
      }
    },
    {
      "name": "All keywords italic",
      "scope": [
        "keyword"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    }
  ],
